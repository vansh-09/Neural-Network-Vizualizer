#!/bin/sh
# Script `a` - examples using grep/egrep, file/directory operations and AWK

set -euo pipefail

usage() {
  cat <<EOF
Usage: a [command]

Commands:
  findmatch <pattern> <path>   - list files and dirs matching name pattern (egrep)
  searchtext <pattern> <file>  - search text in file(s) (grep -n)
  fib <n>                      - print first n Fibonacci numbers (awk)
  pattern <n>                  - display a simple numeric pyramid pattern (awk)
EOF
}

case ${1-} in
  findmatch)
    pattern=${2-'.*'}
    path=${3-'.'}
    echo "Files/dirs in '$path' matching egrep pattern: $pattern"
    # Use egrep (same as grep -E) to match names; list with find then filter
    find "$path" -maxdepth 2 -print | egrep -n --color=auto "$pattern"
    ;;

  searchtext)
    pattern=${2-}
    shift 2
    if [ -z "$pattern" ] || [ $# -eq 0 ]; then
      echo "Provide a pattern and at least one file" >&2
      exit 2
    fi
    # grep with line numbers and show filename when multiple
    grep -n --color=auto -H -- "$pattern" "$@" || true
    ;;

  fib)
    n=${2-10}
    if ! echo "$n" | egrep -q '^[0-9]+$'; then
      echo "n must be a non-negative integer" >&2
      exit 2
    fi
    # AWK Fibonacci: prints first n numbers (0-based)
    awk -v n="$n" 'BEGIN{
      a=0; b=1;
      for(i=0;i<n;i++){
        printf "%d", a;
        if(i<n-1) printf ", ";
        tmp=a+b; a=b; b=tmp;
      }
      printf "\n";
    }'
    ;;

  pattern)
    n=${2-5}
    if ! echo "$n" | egrep -q '^[0-9]+$'; then
      echo "n must be a non-negative integer" >&2
      exit 2
    fi
    # simple numeric pyramid using awk
    awk -v n="$n" 'BEGIN{
      for(i=1;i<=n;i++){
        for(j=1;j<=i;j++) printf "%d ", j;
        printf "\n";
      }
    }'
    ;;

  *)
    usage
    exit 1
    ;;
esac
