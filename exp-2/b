#!/bin/sh
# Script `b` - retrieve system information: OS, processes, memory, env vars

set -euo pipefail

usage() {
  cat <<EOF
Usage: b

Outputs:
  - OS details
  - Kernel and uname
  - Top processes (by CPU and memory)
  - Memory usage summary
  - Logged in users and uptime
  - Selected environment variables
EOF
}

usage
echo

if command -v sw_vers >/dev/null 2>&1; then
  sw_vers || true
fi
uname -a || true

echo
echo "== Uptime & Who =="
uptime || true
who || true

echo
echo "== Top processes (by CPU) =="
ps aux | awk 'NR==1 || $3>0.0 {print}' | sort -k3 -r | head -n 10

echo
echo "== Top processes (by MEM) =="
ps aux | sort -k4 -r | head -n 10

echo
echo "== Memory summary =="
if command -v vm_stat >/dev/null 2>&1; then
  echo "macOS vm_stat output:";
  vm_stat | sed -e 's/\.$//' || true
fi
if command -v free >/dev/null 2>&1; then
  free -h || true
fi

echo
echo "== Disk usage (root) =="
df -h / || true

echo
echo "== Environment (selected) =="
for var in USER HOME SHELL PATH LANG TERM; do
  printf "%s=%s\n" "$var" "${!var-}";
done

echo
echo "== All environment variables (sorted) =="
env | sort
